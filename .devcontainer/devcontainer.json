{
  "name": "Illucidate Development Environment",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "forwardPorts": [5500],
  "portsAttributes": {
    "5500": {
      "label": "Illucidate Web Preview",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y sqlite3 && python -m pip install --upgrade pip",
  "remoteUser": "node"
}
